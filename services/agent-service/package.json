{
  "name": "@telos/agent-service",
  "version": "1.0.0",
  "description": "AI Agent Service with Hono and OpenAI Agents SDK",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "pnpm build && node --test test/*.test.mjs",
    "smoke:volc-realtime": "pnpm build && node scripts/volc-realtime-smoke.mjs",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:push": "prisma db push --schema ../../prisma/schema.prisma",
    "db:studio": "prisma studio --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@ai-sdk/langchain": "2.0.83",
    "@hono/node-server": "^2.0.4",
    "@langchain/core": "1.1.20",
    "@langchain/openai": "1.2.6",
    "@openai/agents": "^0.11.6",
    "@openai/agents-openai": "0.11.6",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "ai": "6.0.78",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "hono": "^4.12.23",
    "openai": "^6.41.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^13.0.0",
    "ws": "^8.21.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.23",
    "@types/pino": "^7.0.5",
    "@types/ws": "^8.18.1",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
