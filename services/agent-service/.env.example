# 数据库配置
DATABASE_URL="postgresql://user:password@localhost:5432/telos"

# DeepSeek API 配置
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxx"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# 字节 Seed 配置
# SEED_API_KEY="xxxxxxxxxxxxxx"
# SEED_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"

# 阿里百炼（DashScope OpenAI 兼容）配置
# BAILIAN_API_KEY="sk-xxxxxxxxxxxxxx"
# BAILIAN_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

# 火山引擎豆包实时语音配置
# 文档: https://www.volcengine.com/docs/6561/1594356?lang=zh
# VOLC_REALTIME_APP_ID="your-app-id"
# VOLC_REALTIME_ACCESS_KEY="your-access-key"
VOLC_REALTIME_ENDPOINT="wss://openspeech.bytedance.com/api/v3/realtime/dialogue"
VOLC_REALTIME_RESOURCE_ID="volc.speech.dialog"
VOLC_REALTIME_APP_KEY="PlgvMymc7f3tQnJ6"
VOLC_REALTIME_MODEL="1.2.1.1"
# Optional TTS speaker. Use a realtime-dialogue compatible speaker id.
# VOLC_REALTIME_SPEAKER="zh_female_vv_jupiter_bigtts"
# VOLC_REALTIME_DEMO=false

# 服务配置
PORT=3001
NODE_ENV="development"

# 日志配置
LOG_LEVEL="info"
